# Server
PORT=3000

# Database
# Local: mongodb://localhost:27017/tienda_informatica
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/tienda_informatica

# JWT - use a long random string (e.g. openssl rand -base64 64)
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria

# Environment: development | production | test
NODE_ENV=development
